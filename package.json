{
  "name": "swiftcut",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nx run desktop:app",
    "dev:web": "nx run desktop:dev",
    "build": "nx run-many -t build",
    "bundle": "nx run desktop:bundle",
    "lint": "nx run-many -t lint",
    "lint:fix": "nx run-many -t lint:fix",
    "typecheck": "nx run-many -t typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "nx run-many -t test",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:gen-types": "supabase gen types typescript --local > packages/supabase/src/types.gen.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@workspace/lint-config": "workspace:*",
    "husky": "^9.1.7",
    "nx": "^23.0.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0"
}
