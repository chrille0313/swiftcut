{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "WebSearch",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:ui.shadcn.com)",
      "WebFetch(domain:radix-ui.com)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:zod.dev)",
      "WebFetch(domain:env.t3.gg)",
      "WebFetch(domain:lucide.dev)",
      "WebFetch(domain:turbo.build)",
      "WebFetch(domain:nx.dev)",
      "WebFetch(domain:tauri.app)",
      "WebFetch(domain:doc.rust-lang.org)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:pnpm.io)",
      "WebFetch(domain:oxc.rs)",
      "WebFetch(domain:commitlint.js.org)",
      "WebFetch(domain:conventionalcommits.org)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:testing-library.com)",
      "WebFetch(domain:deno.com)",
      "WebFetch(domain:docs.deno.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:git-scm.com)",
      "WebFetch(domain:docs.docker.com)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git rebase:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git mv:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm dev:web:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm bundle:*)",
      "Bash(pnpm app:*)",
      "Bash(pnpm tauri:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm format:*)",
      "Bash(pnpm format:check:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm db:*)",
      "Bash(npx supabase:*)",
      "Bash(nx:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(rustup:*)",
      "Bash(rustfmt:*)"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(jq -r '.tool_input.file_path // empty'); case \"$file\" in *.ts|*.tsx|*.mts|*.cts|*.js|*.jsx|*.mjs|*.cjs|*.css) pnpm exec oxlint --fix \"$file\" && pnpm exec oxfmt \"$file\" ;; *.rs) command -v rustfmt >/dev/null 2>&1 && rustfmt --edition 2021 \"$file\" 2>/dev/null || true ;; esac"
          }
        ]
      }
    ]
  }
}
